{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@core/*":           ["packages/core/src/*"],
      "@text-editor/*":    ["packages/text-editor/src/*"],
      "@graphic-editor/*": ["packages/graphic-editor/src/*"],
      "@ui/*":             ["packages/ui/src/*"],
      "@shared/*":         ["shared/*"]
    }
  },
  "include": ["src", "packages", "apps", "shared"]
}
