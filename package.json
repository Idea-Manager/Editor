{
  "name": "idea-editor",
  "version": "0.0.1",
  "private": true,
  "description": "Block text and graphic editor in one workspace—text and graphic modes with embeddable graphic frames in documents",
  "scripts": {
    "dev": "webpack serve --config webpack/webpack.dev.js",
    "build": "webpack --config webpack/webpack.prod.js",
    "build:analyze": "ANALYZE=true webpack --config webpack/webpack.prod.js",
    "test": "jest",
    "check:text-editor-imports": "node scripts/check-text-editor-imports.mjs",
    "docs:dev": "npm --prefix website run start",
    "docs:build": "npm --prefix website run build",
    "docs:serve": "npm --prefix website run serve"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "dotenv-webpack": "^8.1.0",
    "favicons-webpack-plugin": "^6.0.1",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "sass": "^1.87.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "to-string-loader": "^1.2.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.5",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "webpack-merge": "^6.0.1"
  }
}
